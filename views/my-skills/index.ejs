<h2>My Skills</h2>
<div id="skills-list" class="grid">
  <% userSkills.forEach(skill => { %>
    <div class="card" data-skill-id="<%= skill.id %>">
      <span><%= skill.name %></span>
      <button class="btn remove-skill" data-skill-id="<%= skill.id %>">Remove</button>
    </div>
  <% }); %>
</div>

<div class="card">
  <h4>Add a Skill</h4>
  <div id="add-skill-container" style="display:flex; gap:0.5rem; align-items:flex-end;">
    <div class="form-group" style="flex:1;">
      <label for="skill-select">Choose existing skill</label>
      <select id="skill-select">
        <option value="">-- Select --</option>
        <% allSkills.forEach(skill => { %>
          <option value="<%= skill.id %>"><%= skill.name %></option>
        <% }); %>
      </select>
    </div>
    <button type="button" id="add-existing-skill" class="btn">Add</button>
  </div>
  <p style="margin: 1rem 0;">or create a brand‑new skill</p>
  <div style="display:flex; gap:0.5rem;">
    <input type="text" id="new-skill-name" placeholder="e.g. Docker, Figma" style="flex:1;">
    <button type="button" id="create-new-skill" class="btn">Create & Add</button>
  </div>
</div>

<script>
document.getElementById('add-existing-skill').addEventListener('click', async () => {
  const skillId = document.getElementById('skill-select').value;
  if (!skillId) return alert('Please select a skill');
  const res = await fetch('/my-skills', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'Authorization': 'Bearer ' + localStorage.getItem('token')
    },
    body: JSON.stringify({ skillId: parseInt(skillId) })
  });
  if (res.ok) location.reload();
  else {
    const data = await res.json();
    alert('Error: ' + (data.error || 'Failed'));
  }
});

document.getElementById('create-new-skill').addEventListener('click', async () => {
  const name = document.getElementById('new-skill-name').value.trim();
  if (!name) return alert('Skill name is required');

  const createRes = await fetch('/skills', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'Authorization': 'Bearer ' + localStorage.getItem('token')
    },
    body: JSON.stringify({ name })
  });
  if (!createRes.ok) {
    const data = await createRes.json();
    return alert('Error creating skill: ' + (data.error || 'Failed'));
  }
  const newSkill = await createRes.json();
  const skillId = newSkill.id || newSkill.skill?.id;

  const addRes = await fetch('/my-skills', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'Authorization': 'Bearer ' + localStorage.getItem('token')
    },
    body: JSON.stringify({ skillId })
  });
  if (addRes.ok) location.reload();
  else {
    const data = await addRes.json();
    alert('Error adding skill: ' + (data.error || 'Failed'));
  }
});

document.querySelectorAll('.remove-skill').forEach(btn => {
  btn.addEventListener('click', async () => {
    const skillId = btn.dataset.skillId;
    const res = await fetch('/my-skills/' + skillId, {
      method: 'DELETE',
      headers: { 'Authorization': 'Bearer ' + localStorage.getItem('token') }
    });
    if (res.ok) location.reload();
    else alert('Failed to remove skill');
  });
});
</script>
